      "**/.env.*",
      "**/.envrc",
      "**/credentials*.json",
      "**/secrets*.y?ml",
      "**/.bashrc",
      "**/.zshrc",
      "**/.profile",
      "**/.bash_profile",
      "**/*.pem",
      "**/*.key",
      "**/.aws/credentials",
